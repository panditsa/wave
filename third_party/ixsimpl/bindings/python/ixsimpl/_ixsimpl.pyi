from collections.abc import Sequence
from typing import Self, overload

INT: int
RAT: int
SYM: int
ADD: int
MUL: int
FLOOR: int
CEIL: int
MOD: int
PIECEWISE: int
MAX: int
MIN: int
XOR: int
CMP: int
AND: int
OR: int
NOT: int
TRUE: int
FALSE: int
ERROR: int
PARSE_ERROR: int

CMP_GT: int
CMP_GE: int
CMP_LT: int
CMP_LE: int
CMP_EQ: int
CMP_NE: int

class _Expr:
    @property
    def is_error(self) -> bool: ...
    @property
    def is_parse_error(self) -> bool: ...
    @property
    def is_domain_error(self) -> bool: ...
    @property
    def tag(self) -> int: ...
    @property
    def nchildren(self) -> int: ...
    @property
    def children(self) -> tuple[Self, ...]: ...
    def child(self, i: int) -> Self: ...
    @property
    def sym_name(self) -> str: ...
    @property
    def rat_num(self) -> int: ...
    @property
    def rat_den(self) -> int: ...
    @property
    def add_coeff(self) -> Self: ...
    @property
    def add_nterms(self) -> int: ...
    def add_term(self, i: int) -> Self: ...
    def add_term_coeff(self, i: int) -> Self: ...
    @property
    def mul_coeff(self) -> Self: ...
    @property
    def mul_nfactors(self) -> int: ...
    def mul_factor_base(self, i: int) -> Self: ...
    def mul_factor_exp(self, i: int) -> int: ...
    @property
    def pw_ncases(self) -> int: ...
    def pw_value(self, i: int) -> Self: ...
    def pw_cond(self, i: int) -> Self: ...
    @property
    def cmp_op(self) -> int: ...
    def simplify(self, *, assumptions: Sequence[Self] | None = None) -> Self: ...
    def expand(self) -> Self: ...
    def to_c(self) -> str: ...
    @overload
    def subs(self, target: str | Self, replacement: Self | int) -> Self: ...
    @overload
    def subs(self, mapping: dict[str | Self, Self | int]) -> Self: ...
    def __add__(self, other: Self | int) -> Self: ...
    def __radd__(self, other: Self | int) -> Self: ...
    def __sub__(self, other: Self | int) -> Self: ...
    def __rsub__(self, other: Self | int) -> Self: ...
    def __mul__(self, other: Self | int) -> Self: ...
    def __rmul__(self, other: Self | int) -> Self: ...
    def __truediv__(self, other: Self | int) -> Self: ...
    def __rtruediv__(self, other: Self | int) -> Self: ...
    def __neg__(self) -> Self: ...
    def __ge__(self, other: Self | int) -> Self: ...
    def __gt__(self, other: Self | int) -> Self: ...
    def __le__(self, other: Self | int) -> Self: ...
    def __lt__(self, other: Self | int) -> Self: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __hash__(self) -> int: ...
    def __int__(self) -> int: ...
    def __repr__(self) -> str: ...
    def __str__(self) -> str: ...
    def __bool__(self) -> bool: ...
    @property
    def _ctx(self) -> Context: ...

class Context:
    def __init__(self) -> None: ...
    def sym(self, name: str) -> _Expr: ...
    def parse(self, input: str) -> _Expr: ...
    def int_(self, val: int) -> _Expr: ...
    def rat(self, p: int, q: int) -> _Expr: ...
    def true_(self) -> _Expr: ...
    def false_(self) -> _Expr: ...
    def eq(self, a: _Expr | int, b: _Expr | int) -> _Expr: ...
    def ne(self, a: _Expr | int, b: _Expr | int) -> _Expr: ...
    def check(
        self,
        expr: _Expr,
        *,
        assumptions: Sequence[_Expr] | None = None,
    ) -> bool | None: ...
    def simplify_batch(
        self,
        exprs: Sequence[_Expr],
        *,
        assumptions: Sequence[_Expr] | None = None,
    ) -> None: ...
    def clear_errors(self) -> None: ...
    @property
    def errors(self) -> list[str]: ...
    def stats(self) -> dict[str, int]: ...
    def stats_reset(self) -> None: ...

def floor(expr: _Expr) -> _Expr: ...
def ceil(expr: _Expr) -> _Expr: ...
def mod(a: _Expr, b: _Expr | int) -> _Expr: ...
def max_(a: _Expr, b: _Expr | int) -> _Expr: ...
def min_(a: _Expr, b: _Expr | int) -> _Expr: ...
def xor_(a: _Expr, b: _Expr | int) -> _Expr: ...
def and_(a: _Expr, b: _Expr | int) -> _Expr: ...
def or_(a: _Expr, b: _Expr | int) -> _Expr: ...
def not_(a: _Expr) -> _Expr: ...
def pw(*branches: tuple[_Expr | int, _Expr | int]) -> _Expr: ...
def same_node(a: _Expr, b: _Expr) -> bool: ...
def _set_expr_class(cls: type[_Expr]) -> None: ...
